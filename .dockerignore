# Keep the build context lean — only what the Dockerfile COPYs is needed.
.git
.github
.mypy_cache
.pytest_cache
.ruff_cache
.venv
dist
build
*.egg-info

# Dev-only — bake the venv fresh inside the image.
tests
scripts

# Environment artifacts that shouldn't be baked in.
.env
.env.*
!.env.example

# OS / editor crud
.DS_Store
Thumbs.db
*.swp
*.swo
.idea
.vscode

# Coverage / cache
.coverage
.coverage.*
htmlcov
coverage.xml

# Docs we don't need at runtime
CONTRIBUTING.md
CLAUDE.md
CHANGELOG.md
