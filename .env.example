# Unraid MCP Server Configuration
# Copy to .env and fill in your values

# Mode: "readonly" (default) or "readwrite"
# In readonly mode, write tools are completely hidden from MCP clients
UNRAID_MODE=readonly

# ─── Unraid GraphQL API ───────────────────────────────────────────────────────
# Hostname or IP of your Unraid server. Enable the API in
# Settings → Management Access → Developer Options.
UNRAID_HOST=tower.local
UNRAID_PORT=443
UNRAID_USE_HTTPS=true

# API key generated via the Unraid WebGUI or `unraid-api apikey --create`
UNRAID_API_KEY=

# Set to true if your Unraid server has a valid TLS cert. For self-signed
# certs (typical on a LAN appliance) leave this false.
UNRAID_VERIFY_SSL=false

# ─── General ──────────────────────────────────────────────────────────────────
UNRAID_REQUEST_TIMEOUT=30        # Request timeout in seconds
UNRAID_MAX_RETRIES=3             # Max retry attempts on connection errors
